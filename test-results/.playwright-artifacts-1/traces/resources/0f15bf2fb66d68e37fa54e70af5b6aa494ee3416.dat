    <h1>Net Balance</h1>
    <span class="text-green-600">{{ summary()?.netBalance | currency : 'ZAR'}}</span>
  </div>
</div>
<h1 class="text-center text-2xl md:text-4xl mb-4">Income vs Expense over time(Months)</h1>
<app-chart
